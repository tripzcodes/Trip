# Textured cube
mtllib cube.mtl
usemtl checker

v -1  0 -1
v  1  0 -1
v  1  2 -1
v -1  2 -1
v -1  0  1
v  1  0  1
v  1  2  1
v -1  2  1

vn  0  0 -1
vn  0  0  1
vn  1  0  0
vn -1  0  0
vn  0  1  0
vn  0 -1  0

vt 0 0
vt 1 0
vt 1 1
vt 0 1

# front (-Z)
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1
# back (+Z)
f 6/1/2 5/2/2 8/3/2
f 6/1/2 8/3/2 7/4/2
# right (+X)
f 2/1/3 6/2/3 7/3/3
f 2/1/3 7/3/3 3/4/3
# left (-X)
f 5/1/4 1/2/4 4/3/4
f 5/1/4 4/3/4 8/4/4
# top (+Y)
f 4/1/5 3/2/5 7/3/5
f 4/1/5 7/3/5 8/4/5
# bottom (-Y)
f 5/1/6 6/2/6 2/3/6
f 5/1/6 2/3/6 1/4/6
